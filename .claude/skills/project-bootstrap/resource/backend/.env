# ===========================================
# CORE APPLICATION
# ===========================================
PORT=3007
MODE=DEV
ALLOW_ORIGINS=http://localhost:4007,http://localhost:3007
FRONTEND_URL=http://localhost:4007
APP_URL=http://localhost:3007

# ===========================================
# DATABASE
# ===========================================
DB_TYPE=mysql        # mysql | postgres
DB_HOST=localhost
DB_PORT=3306         # 3306 for MySQL/MariaDB | 5432 for PostgreSQL
DB_USER=mhrana
DB_PASSWORD=rana12
DB_NAME=meal_management

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=3600s
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRATION=7d

# ===========================================
# MULTI-TENANCY
# ===========================================
TENANT_ID=
USE_TENANT_MODE=false
ENABLE_COMPANY_FEATURE=false

# ===========================================
# REDIS (optional — defaults to redis://localhost:6379)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# STORAGE
# ===========================================
MAX_FILE_SIZE=209715200
ALLOWED_FILE_TYPES=image/*,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/*

# ===========================================
# ADMIN CREDENTIALS (for seed-admin.ts)
# ===========================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456
