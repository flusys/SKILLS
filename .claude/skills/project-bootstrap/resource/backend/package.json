{
  "name": "my-app-backend",
  "version": "0.0.1",
  "description": "My App Backend API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "migration": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/@flusys/nestjs-core/cjs/migration/cli.js",
    "migration:generate": "npm run migration -- generate",
    "migration:run": "npm run migration -- run",
    "migration:revert": "npm run migration -- revert",
    "migration:status": "npm run migration -- status",
    "migration:run:all": "npm run migration -- run:all",
    "seed": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/@flusys/nestjs-core/cjs/seeders/cli.js",
    "seed:generate": "npm run seed -- generate",
    "seed:run": "npm run seed -- run",
    "seed:clear": "npm run seed -- clear"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@flusys/nestjs-auth": "^5.0.0",
    "@flusys/nestjs-core": "^5.0.0",
    "@flusys/nestjs-email": "^5.0.0",
    "@flusys/nestjs-event-manager": "^5.0.0",
    "@flusys/nestjs-form-builder": "^5.0.0",
    "@flusys/nestjs-iam": "^5.0.0",
    "@flusys/nestjs-localization": "^5.0.0",
    "@flusys/nestjs-notification": "^5.0.0",
    "@flusys/nestjs-shared": "^5.0.0",
    "@flusys/nestjs-storage": "^5.0.0",
    "@keyv/redis": "^5.1.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.13",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cacheable": "^2.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "keyv": "^5.6.0",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "mysql2": "^3.14.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0",
    "uuid": "^11.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@types/cookie-parser": "^1.4.0",
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.2",
    "@types/passport-jwt": "^4.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
